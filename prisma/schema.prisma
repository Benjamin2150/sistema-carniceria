// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "file:./dev.db"
}

// 1. USUARIO ADMIN
model Usuario {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

// 2. PRODUCTOS (BODEGA)
model Producto {
  id         Int          @id @default(autoincrement())
  nombre     String
  precio     Int
  categoria  String
  plu        Int?         @unique
  imagen     String?      // Ruta de la foto
  disponible Boolean      @default(true)
  oferta     Boolean      @default(false)
  items      ItemPedido[]
}

// 3. PEDIDOS (COMANDAS)
model Pedido {
  id            Int          @id @default(autoincrement())
  fecha         DateTime     @default(now())
  nombreCliente String
  telefono      String?
  total         Int
  estado        String       @default("PENDIENTE") // PENDIENTE, PREPARACION, LISTO, ENTREGADO
  items         ItemPedido[]
}

model ItemPedido {
  id         Int      @id @default(autoincrement())
  cantidad   Int
  precio     Int
  subtotal   Int
  pedidoId   Int
  pedido     Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
}

// 4. PERSONAL (RRHH) - ¡ESTO FALTABA!
model Empleado {
  id           Int      @id @default(autoincrement())
  nombre       String
  cargo        String
  sueldoBase   Int
  tipoContrato String
  fechaIngreso DateTime @default(now())
}

// 5. RED DE PESAS (DIGI) - ¡ESTO TAMBIÉN!
model Balanza {
  id     Int    @id @default(autoincrement())
  nombre String
  ip     String
}